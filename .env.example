# ── Rick & Morty Wiki — environment variables ──────────────────────────────
# Only VITE_-prefixed vars are exposed to the client (Vite rule), and they are
# read in exactly one place: src/shared/config/env.ts. Copy this file to
# `.env.local` and adjust. There are no secrets here — the API is public.

# Base URL of the Rick & Morty REST API. Every request is built on top of this
# in infrastructure/api/rick-morty.client.ts. Override it to point the app at a
# proxy or a recorded-fixture server; leave as-is to hit the public API.
VITE_API_BASE_URL=https://rickandmortyapi.com/api

# Enables MSW (Mock Service Worker) request mocking — DEV only, "true" / "false".
# When "true", main.tsx starts the MSW worker so the app runs against the mock
# handlers in infrastructure/mocks/ instead of the live API (deterministic data
# for local work and the Playwright E2E suite). Keep "false" for real API data.
VITE_ENABLE_MSW=false
